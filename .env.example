# Copy this file to .env and adjust if needed.
# Every value below is optional — the defaults shown are what the code uses.

# Backend environment variables

# Port for the WebSocket relay and the /health endpoint (default: 8090).
# Both are served on this single port.
PORT=8090

# Frame interval for replay mode in milliseconds (default: 100 = real time).
# Lower is faster: 50 is 2x speed, 25 is 4x.
REPLAY_INTERVAL=100

# Optional. Sent as an Authorization header during SignalR Core negotiation.
# The feed currently connects without it; set it only if negotiation begins
# failing. Never commit a real token.
# F1_BEARER_TOKEN=

# Frontend environment variables
# These are inlined at build time, so rebuild the frontend after changing them.

# Backend URL used by the frontend for health checks (default: http://localhost:8090)
NEXT_PUBLIC_API_URL=http://localhost:8090

# WebSocket relay URL used by the frontend for live data (default: ws://localhost:8090/ws)
NEXT_PUBLIC_WS_URL=ws://localhost:8090/ws
